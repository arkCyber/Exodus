# Exodus Browser — copy to .env for local development (never commit .env)
# Tauri/Vite reads these when configured in tauri.conf / vite.

# Vite dev server (default in tauri dev)
# VITE_DEV_SERVER_URL=http://localhost:1420

# Optional: enable verbose startup logging
# RUST_LOG=info,exodus_startup=info

# IM integration tests (Rust) — requires network setup
# EXODUS_RUN_IM_TESTS=1
