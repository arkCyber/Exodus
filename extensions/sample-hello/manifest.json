{
  "manifest_version": 3,
  "name": "Exodus Sample Hello",
  "version": "1.0.0",
  "description": "Marks pages visited by Exodus Web Extension MVP (dev sample).",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["*://localhost/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Exodus Sample",
    "default_popup": "popup.html"
  }
}
