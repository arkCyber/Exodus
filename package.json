{
  "name": "exodus",
  "version": "0.1.0",
  "description": "Exodus — privacy-first AI browser (Tauri + SvelteKit)",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:frontend": "pnpm check && pnpm test",
    "test:rust": "cargo test -p exodus-core && sh scripts/cargo-test-non-im.sh",
    "test:rust:im": "cargo test -p exodus-tauri --manifest-path src-tauri/Cargo.toml --features im-tests -- --test-threads=2",
    "test:quick": "sh scripts/test-quick.sh",
    "build:sidecar": "sh scripts/install-sidecar.sh",
    "ensure:sidecar": "sh scripts/ensure-sidecar.sh",
    "verify": "sh scripts/verify.sh",
    "sync-server": "node scripts/sync-vault-server.mjs",
    "hooks:install": "sh scripts/install-git-hooks.sh",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.10.0",
    "vitest": "^3.0.0"
  }
}
