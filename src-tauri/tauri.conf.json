{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Exodus",
  "version": "0.1.0",
  "identifier": "com.exodus.browser",
  "build": {
    "beforeDevCommand": "sh scripts/tauri-before-dev.sh",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "sh scripts/bun-build.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Exodus",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "visible": true,
        "focus": true,
        "decorations": true,
        "center": true,
        "resizable": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPCONFIG/**",
          "$RESOURCE/**"
        ]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/exodus-core"],
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "hardenedRuntime": false
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
